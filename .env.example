# Census API Key (optional - increases rate limits from 500 to 5,000 requests per day)
# Get yours at: https://api.census.gov/data/key_signup.html
REACT_APP_CENSUS_API_KEY=

# Mapbox API Key (optional - for enhanced geocoding and mapping)
# Get yours at: https://www.mapbox.com/
REACT_APP_MAPBOX_TOKEN=

# Google Analytics (optional - for usage tracking)
REACT_APP_GA_TRACKING_ID=

# Environment
REACT_APP_ENV=production
